#!/usr/bin/env bash
set -euo pipefail

GREEN="\033[0;32m"
NC="\033[0m"
DEFAULT_CLONE_DIR="$HOME"

choose_mods_gui() {
  dest="$1"
  mkdir -p "$dest"

  applescript='
    tell application "System Events"
      activate
      try
        set theFiles to choose file with prompt "Choose NeoForge mod files (Command/Shift for multiple):" of type {"jar"} with multiple selections allowed
      on error
        return ""
      end try
      set thePOSIX to {}
      repeat with f in theFiles
        copy POSIX path of f to the end of thePOSIX
      end repeat
      return thePOSIX as string
    end tell
  '
  selected="$(osascript -e "$applescript")"
  [ -z "$selected" ] && return

  IFS=", " read -r -a files <<< "$selected"
  for f in "${files[@]}"; do
    [ -f "$f" ] && cp "$f" "$dest/"
  done
}

open_folder_in_finder() {
  path="$1"
  [ -d "$path" ] && open "$path"
}

run_neoforge_setup() {
  local DEFAULT_NEO_PROJECT_NAME="Minecrak Neo"
  local DEFAULT_NEO_VERSION="1.21.1"

  echo -e "${GREEN}=== NeoForge Dev Setup ===${NC}"
  read -r -p "NeoForge Minecraft version [$DEFAULT_NEO_VERSION]: " NEO_VERSION_CHOICE
  NEO_VERSION_CHOICE="${NEO_VERSION_CHOICE:-$DEFAULT_NEO_VERSION}"
  local NEO_MDK_REPO="https://github.com/NeoForgeMDKs/MDK-${NEO_VERSION_CHOICE}-NeoGradle.git"
  echo
  read -r -p "NeoForge project name [$DEFAULT_NEO_PROJECT_NAME]: " NEO_PROJECT_NAME
  NEO_PROJECT_NAME="${NEO_PROJECT_NAME:-$DEFAULT_NEO_PROJECT_NAME}"
  echo
  echo "NeoForge project base directory (default: $DEFAULT_CLONE_DIR)"
  read -r -p "Path (ENTER for default): " NEO_CLONE_DIR
  NEO_CLONE_DIR="${NEO_CLONE_DIR:-$DEFAULT_CLONE_DIR}"
  NEO_CLONE_DIR="${NEO_CLONE_DIR%/}"
  NEO_PROJECT_DIR="$NEO_CLONE_DIR/$NEO_PROJECT_NAME"

  while [ -d "$NEO_PROJECT_DIR" ] && [ "$(ls -A "$NEO_PROJECT_DIR" 2>/dev/null | wc -l)" -gt 0 ]; do
    echo
    echo "Directory '$NEO_PROJECT_DIR' already exists and is not empty."
    echo "What do you want to do?"
    echo "  1) Delete it and recreate"
    echo "  2) Enter a different project name"
    echo "  3) Abort"
    read -r -p "Choice [1/2/3]: " EXIST_CHOICE
    case "$EXIST_CHOICE" in
      1)
        rm -rf "$NEO_PROJECT_DIR"
        echo "Deleted '$NEO_PROJECT_DIR'."
        ;;
      2)
        read -r -p "New NeoForge project name: " NEO_PROJECT_NAME
        NEO_PROJECT_NAME="${NEO_PROJECT_NAME:-$DEFAULT_NEO_PROJECT_NAME}"
        NEO_PROJECT_DIR="$NEO_CLONE_DIR/$NEO_PROJECT_NAME"
        ;;
      3)
        echo "Aborting NeoForge setup."
        return 1
        ;;
      *)
        echo "Invalid choice."
        ;;
    esac
  done

  echo
  echo -e "${GREEN}[N-1/5] Cloning NeoForge MDK to '$NEO_PROJECT_DIR'...${NC}"
  git clone "$NEO_MDK_REPO" "$NEO_PROJECT_DIR"
  cd "$NEO_PROJECT_DIR"

  echo -e "${GREEN}[N-2/5] Forcing gameDirectory to 'runs/client'...${NC}"
  if grep -q "neoForge {" build.gradle; then
    sed -i.bak ' /neoForge\s*{/,/}/ { /runs\s*{/,/}/ { /client\s*{/,/}/ { /gameDirectory/d /client\s*{/a\ \ \ \ \ \ \ \ \ gameDirectory = project.file("runs/client") } } } ' build.gradle
  fi

  local NEO_RUN_DIR="runs/client"
  mkdir -p "$NEO_RUN_DIR/mods" "$NEO_RUN_DIR/config"

  echo -e "${GREEN}[N-3/5] Select NeoForge mods now? (y/N)${NC}"
  read -r MODS_CHOICE
  if [ "$MODS_CHOICE" = "y" ] || [ "$MODS_CHOICE" = "Y" ]; then
    choose_mods_gui "$NEO_RUN_DIR/mods"
  fi

  echo -e "${GREEN}[N-4/5] Creating start-neoforge.command...${NC}"
  cat > start-neoforge.command <<EOF
#!/usr/bin/env bash
set -euo pipefail
cd "\$(dirname "\$0")"
./gradlew runClient
EOF
  chmod +x start-neoforge.command

  echo -e "${GREEN}[N-5/5] Creating uninstall-neoforge.command...${NC}"
  cat > uninstall-neoforge.command <<EOF
#!/usr/bin/env bash
echo "This will delete the NeoForge project at:"
echo " $NEO_PROJECT_DIR"
read -r -p "Type 'DELETE' to confirm: " ans
if [ "\$ans" = "DELETE" ]; then
  rm -rf "$NEO_PROJECT_DIR"
  echo "Deleted."
else
  echo "Cancelled."
fi
EOF
  chmod +x uninstall-neoforge.command

  open_folder_in_finder "$NEO_RUN_DIR/mods"

  echo
  echo -e "${GREEN}=== NeoForge setup complete ===${NC}"
  echo "Project: $NEO_PROJECT_DIR"
  echo "Mods:    $NEO_PROJECT_DIR/runs/client/mods"
  echo "Config:  $NEO_PROJECT_DIR/runs/client/config"
  echo "Run client: double-click start-neoforge.command"
}

run_neoforge_setup
