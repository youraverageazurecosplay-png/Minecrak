#!/usr/bin/env bash
set -euo pipefail

GREEN="\033[0;32m"
NC="\033[0m"
DEFAULT_CLONE_DIR="$HOME"

move_mods_and_config() {
  BASE_DIR="$1"

  SOURCE="$BASE_DIR/mods"
  TARGET_MODS="$BASE_DIR/runs/client/mods"
  TARGET_CONFIG="$BASE_DIR/runs/client/config"

  mkdir -p "$TARGET_MODS"
  mkdir -p "$TARGET_CONFIG"

  # Move mod jars
  if [ -d "$SOURCE" ]; then
    find "$SOURCE" -maxdepth 1 -type f -name '*.jar' -exec mv {} "$TARGET_MODS"/ \;
  fi

  # Move config folder if present
  if [ -d "$SOURCE/config" ]; then
    echo "Importing config folder..."
    rm -rf "$TARGET_CONFIG"
    mv "$SOURCE/config" "$TARGET_CONFIG"
  fi
}

close_finder_window() {
  osascript <<EOF 2>/dev/null || true
tell application "Finder"
    try
        set targetPath to POSIX file "$1" as alias
        repeat with w in windows
            if (target of w as alias) is targetPath then
                close w
            end if
        end repeat
    end try
end tell
EOF
}

run_neoforge_setup() {

  DEFAULT_NEO_PROJECT_NAME="Minecrak Neo"
  DEFAULT_NEO_VERSION="1.21.1"

  echo -e "${GREEN}=== NeoForge Dev Setup ===${NC}"

  read -r -p "NeoForge Minecraft version [$DEFAULT_NEO_VERSION]: " NEO_VERSION_CHOICE
  NEO_VERSION_CHOICE="${NEO_VERSION_CHOICE:-$DEFAULT_NEO_VERSION}"

  NEO_MDK_REPO="https://github.com/NeoForgeMDKs/MDK-${NEO_VERSION_CHOICE}-NeoGradle.git"

  echo
  read -r -p "NeoForge project name [$DEFAULT_NEO_PROJECT_NAME]: " NEO_PROJECT_NAME
  NEO_PROJECT_NAME="${NEO_PROJECT_NAME:-$DEFAULT_NEO_PROJECT_NAME}"

  echo
  echo "NeoForge project base directory (default: $DEFAULT_CLONE_DIR)"
  read -r -p "Path (ENTER for default): " NEO_CLONE_DIR
  NEO_CLONE_DIR="${NEO_CLONE_DIR:-$DEFAULT_CLONE_DIR}"
  NEO_CLONE_DIR="${NEO_CLONE_DIR%/}"

  NEO_PROJECT_DIR="$NEO_CLONE_DIR/$NEO_PROJECT_NAME"

  echo
  echo -e "${GREEN}[1/6] Cloning NeoForge MDK...${NC}"
  git clone "$NEO_MDK_REPO" "$NEO_PROJECT_DIR" || return
  cd "$NEO_PROJECT_DIR" || return

  mkdir -p runs/client/mods
  mkdir -p runs/client/config

  echo -e "${GREEN}[2/6] Add mods + config now? (y/N)${NC}"
  read -r SELECT_MODS || true

  if [[ "$SELECT_MODS" =~ ^[Yy]$ ]]; then
    mkdir -p "$NEO_PROJECT_DIR/mods"
    open "$NEO_PROJECT_DIR/mods"

    echo
    echo "Place:"
    echo "  - .jar files"
    echo "  - optional config folder"
    echo "Into:"
    echo "  $NEO_PROJECT_DIR/mods"
    echo

    read -r -p "Press ENTER when done..." _

    close_finder_window "$NEO_PROJECT_DIR/mods"
    move_mods_and_config "$NEO_PROJECT_DIR"
  fi

  echo -e "${GREEN}[3/6] Creating launcher...${NC}"

  cat > start-neoforge.command <<EOF
#!/usr/bin/env bash
set -euo pipefail

NEO_PROJECT_DIR="$NEO_PROJECT_DIR"

move_mods_and_config() {
  BASE_DIR="\$1"

  SOURCE="\$BASE_DIR/mods"
  TARGET_MODS="\$BASE_DIR/runs/client/mods"
  TARGET_CONFIG="\$BASE_DIR/runs/client/config"

  mkdir -p "\$TARGET_MODS"
  mkdir -p "\$TARGET_CONFIG"

  if [ -d "\$SOURCE" ]; then
    find "\$SOURCE" -maxdepth 1 -type f -name '*.jar' -exec mv {} "\$TARGET_MODS"/ \;
  fi

  if [ -d "\$SOURCE/config" ]; then
    echo "Importing config folder..."
    rm -rf "\$TARGET_CONFIG"
    mv "\$SOURCE/config" "\$TARGET_CONFIG"
  fi
}

cd "\$NEO_PROJECT_DIR"

echo "Clean mods folder before moving? (y/N)"
read -r CLEAN

if [[ "\$CLEAN" =~ ^[Yy]$ ]]; then
  rm -f "\$NEO_PROJECT_DIR/runs/client/mods"/*.jar 2>/dev/null || true
fi

move_mods_and_config "\$NEO_PROJECT_DIR"

./gradlew runClient -DgameDir=runs/client
EOF

  chmod +x start-neoforge.command

  echo -e "${GREEN}[4/6] Creating uninstall...${NC}"

  cat > uninstall-neoforge.command <<EOF
#!/usr/bin/env bash
echo "Delete $NEO_PROJECT_DIR ?"
read -r -p "Type DELETE to confirm: " ans
if [ "\$ans" = "DELETE" ]; then
  rm -rf "$NEO_PROJECT_DIR"
  echo "Deleted."
else
  echo "Cancelled."
fi
EOF

  chmod +x uninstall-neoforge.command

  echo -e "${GREEN}[5/6] Run client now? (y/N)${NC}"
  read -r RUN_NOW || true

  if [[ "$RUN_NOW" =~ ^[Yy]$ ]]; then
    move_mods_and_config "$NEO_PROJECT_DIR"
    ./gradlew runClient -DgameDir=runs/client
  fi

  echo
  echo -e "${GREEN}=== Setup Complete ===${NC}"
  echo "Project: $NEO_PROJECT_DIR"
  echo "Mods:    $NEO_PROJECT_DIR/runs/client/mods"
  echo "Config:  $NEO_PROJECT_DIR/runs/client/config"
  echo "Launcher: start-neoforge.command"
}

run_neoforge_setup
