#!/usr/bin/env bash
set -euo pipefail

GREEN="\033[0;32m"
NC="\033[0m"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
FABRIC_LOCAL="$SCRIPT_DIR/Fabrik"
NEO_LOCAL="$SCRIPT_DIR/NeoForg"

FABRIC_URL="https://raw.githubusercontent.com/youraverageazurecosplay-png/Minecrak/refs/heads/main/Fabrik"
NEO_URL="https://raw.githubusercontent.com/youraverageazurecosplay-png/Minecrak/refs/heads/main/NeoForg"

prompt_loader_choice() {
  echo -e "${GREEN}=== Minecrak Dev Setup ===${NC}"
  echo
  echo "What do you want to do?"
  select opt in "Fabric" "NeoForge" "Install tools (Homebrew/Java 21/Gradle)" "Quit"; do
    case "$opt" in
      "Fabric") LOADER="Fabric"; break ;;
      "NeoForge") LOADER="NeoForge"; break ;;
      "Install tools (Homebrew/Java 21/Gradle)") LOADER="Tools"; break ;;
      "Quit") LOADER="Quit"; break ;;
      *) echo "Invalid choice."; ;;
    esac
  done
}

ensure_local_copy() {
  url="$1"
  local_path="$2"
  curl -fsSL "$url" -o "$local_path"
  chmod +x "$local_path"
}

install_tools() {
  echo -e "${GREEN}=== Installing required tools ===${NC}"
  echo

  if ! command -v brew >/dev/null 2>&1; then
    echo "Homebrew not found. Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [ -d "/opt/homebrew/bin" ]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -d "/usr/local/bin" ]; then
      export PATH="/usr/local/bin:$PATH"
    fi
  else
    echo "Homebrew is already installed."
  fi

  echo
  echo "Checking Java (need Java 21 for 1.21.x)..."
  if ! command -v java >/dev/null 2>&1; then
    echo "Java not found. Installing Temurin JDK 21 via Homebrew..."
    brew install --cask temurin@21 || brew install --cask temurin
  else
    echo "Java is installed:"
    java -version
  fi

  echo
  echo "Checking Java version (expect 21.x)..."
  if command -v java >/dev/null 2>&1; then
    java -version
    echo "If this is lower than 21, update JAVA_HOME / PATH to point to Java 21."
  else
    echo "Java still not found. Install Java 21 manually from https://adoptium.net."
  fi

  echo
  echo "Checking Gradle..."
  if ! command -v gradle >/dev/null 2>&1; then
    echo "Gradle not found. Installing Gradle via Homebrew..."
    brew install gradle
  else
    echo "Gradle is already installed."
  fi

  echo
  echo -e "${GREEN}Tool check complete.${NC}"
}

main() {
  prompt_loader_choice
  case "$LOADER" in
    "Fabric")
      ensure_local_copy "$FABRIC_URL" "$FABRIC_LOCAL"
      "$FABRIC_LOCAL"
      ;;
    "NeoForge")
      ensure_local_copy "$NEO_URL" "$NEO_LOCAL"
      "$NEO_LOCAL"
      ;;
    "Tools")
      install_tools
      ;;
    "Quit")
      echo "Bye."
      exit 0
      ;;
  esac
}

main
