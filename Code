#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$0"

# ====== GLOBAL DEFAULTS ======
DEFAULT_CLONE_DIR="$HOME"
DEFAULT_FABRIC_PROJECT_NAME="Minecrak Fabric"
DEFAULT_NEO_PROJECT_NAME="Minecrak Neo"

# Fabric defaults
DEFAULT_FABRIC_VERSION="1.21.11"
FABRIC_EXAMPLE_REPO="https://github.com/FabricMC/fabric-example-mod"

# NeoForge defaults
DEFAULT_NEO_VERSION="1.21.1"  # just a default; user can override
# MDK URL will be built as: https://github.com/NeoForgeMDKs/MDK-${NEO_VERSION}-NeoGradle.git

# Fun stuff
ENTERTAINMENT_URL="https://www.youtube.com"

GREEN="\033[0;32m"
NC="\033[0m"

CREATED_PROJECT_DIR=""

cleanup() {
  if [ -n "${CREATED_PROJECT_DIR:-}" ] && [ -d "$CREATED_PROJECT_DIR" ]; then
    echo
    echo -e "${GREEN}[CLEANUP] Removing incomplete project directory:${NC}"
    echo "  $CREATED_PROJECT_DIR"
    rm -rf "$CREATED_PROJECT_DIR"
  fi

  # Best-effort removal of the installer script file (for <(curl ...) usage)
  if [ -n "${SCRIPT_PATH:-}" ] && [ -f "$SCRIPT_PATH" ]; then
    echo -e "${GREEN}[CLEANUP] Removing installer script file: $SCRIPT_PATH${NC}"
    rm -f "$SCRIPT_PATH" || true
  fi
}
trap cleanup EXIT

# ====== COMMON PROMPTS ======

prompt_loader_choice() {
  echo -e "${GREEN}=== Minecrak Dev Setup ===${NC}"
  echo
  echo "Which loader do you want?"
  select opt in "Fabric" "NeoForge"; do
    case "$opt" in
      "Fabric") LOADER="Fabric"; break ;;
      "NeoForge") LOADER="NeoForge"; break ;;
      *) echo "Invalid choice."; ;;
    esac
  done
}

prompt_entertainment_choice() {
  echo
  echo "Open something entertaining in your browser while it downloads?"
  echo "Current URL: $ENTERTAINMENT_URL"
  select opt in "Yes" "No"; do
    case "$opt" in
      "Yes") OPEN_FUN="Yes"; break ;;
      "No")  OPEN_FUN="No";  break ;;
      *) echo "Invalid choice."; ;;
    esac
  done
}

prompt_make_command_and_run_now() {
  echo
  echo "Create a 'runClient' helper script in your home folder?"
  select opt in "Yes" "No"; do
    case "$opt" in
      "Yes") MAKE_COMMAND="Yes"; break ;;
      "No")  MAKE_COMMAND="No";  break ;;
      *) echo "Invalid choice."; ;;
    esac
  done

  echo
  echo "Run the dev client after setup?"
  select opt in "Yes" "No"; do
    case "$opt" in
      "Yes") RUN_CLIENT_NOW="Yes"; break ;;
      "No")  RUN_CLIENT_NOW="No";  break ;;
      *) echo "Invalid choice."; ;;
    esac
  done
}

prompt_clone_dir_and_project_name() {
  local default_name="$1"
  local project_var_name="$2"   # NEOPROJECT_NAME or FABRIC_PROJECT_NAME

  echo
  read -r -p "Project name [$default_name]: " pname
  pname="${pname:-$default_name}"

  echo
  echo "Where should the project folder be created?"
  echo "1) Use default (home folder: $DEFAULT_CLONE_DIR)"
  echo "2) Choose a custom directory"
  while true; do
    read -r -p "Select 1 or 2 [1]: " clone_choice
    clone_choice="${clone_choice:-1}"
    case "$clone_choice" in
      1)
        CLONE_DIR="$DEFAULT_CLONE_DIR"
        break
        ;;
      2)
        while true; do
          read -r -p "Enter custom clone directory path: " custom_dir
          if [ -d "$custom_dir" ]; then
            CLONE_DIR="$custom_dir"
            break
          else
            echo "Directory '$custom_dir' does not exist. Try again."
          fi
        done
        break
        ;;
      *)
        echo "Invalid choice, enter 1 or 2."
        ;;
    esac
  done
  CLONE_DIR="${CLONE_DIR%/}"

  # Export into the right variables via indirect expansion
  if [ "$project_var_name" = "NEOPROJECT_NAME" ]; then
    NEOPROJECT_NAME="$pname"
    NEO_CLONE_DIR="$CLONE_DIR"
    NEO_PROJECT_DIR="$NEO_CLONE_DIR/$NEOPROJECT_NAME"
  else
    FABRIC_PROJECT_NAME="$pname"
    FABRIC_CLONE_DIR="$CLONE_DIR"
    FABRIC_PROJECT_DIR="$FABRIC_CLONE_DIR/$FABRIC_PROJECT_NAME"
  fi
}

prompt_extra_mods_list() {
  echo
  echo "Do you want to add extra mods to the dev instance?"
  select opt in "No" "Yes"; do
    case "$opt" in
      "No")  MODS_CHOICE="No";  EXTRA_MODS=""; break ;;
      "Yes") MODS_CHOICE="Yes"; break ;;
      *) echo "Invalid choice."; ;;
    esac
  done

  if [ "$MODS_CHOICE" = "Yes" ]; then
    echo
    echo "Paste full paths to mods (jars), one per line."
    echo "End with an empty line."
    EXTRA_MODS=""
    while IFS= read -r line; do
      [ -z "$line" ] && break
      EXTRA_MODS+="${line}"$'\n'
    done
  fi
}

# ====== FABRIC FLOW ======

run_fabric_setup() {
  echo
  echo -e "${GREEN}=== Fabric Example Mod dev setup (macOS) ===${NC}"

  # Version (simple free text, default)
  read -r -p "Minecraft version for Fabric [$DEFAULT_FABRIC_VERSION]: " MC_VERSION
  MC_VERSION="${MC_VERSION:-$DEFAULT_FABRIC_VERSION}"

  prompt_clone_dir_and_project_name "$DEFAULT_FABRIC_PROJECT_NAME" "FABRIC_PROJECT_NAME"
  prompt_extra_mods_list
  FABRIC_MODS_CHOICE="$MODS_CHOICE"
  FABRIC_EXTRA_MODS="$EXTRA_MODS"

  echo
  echo -e "${GREEN}=== Summary (Fabric) ===${NC}"
  echo "Project name:       $FABRIC_PROJECT_NAME"
  echo "Clone directory:    $FABRIC_CLONE_DIR"
  echo "Full project path:  $FABRIC_PROJECT_DIR"
  echo "Minecraft version:  $MC_VERSION"
  echo "Extra mods choice:  $FABRIC_MODS_CHOICE"
  [ "$FABRIC_MODS_CHOICE" = "Yes" ] && echo "Extra mods list:    (paths shown below):" && printf "%s" "$FABRIC_EXTRA_MODS"
  echo "========================"

  if [ -d "$FABRIC_PROJECT_DIR" ]; then
    echo
    echo -e "${GREEN}Directory '$FABRIC_PROJECT_DIR' already exists, aborting to avoid overwrite.${NC}"
    exit 1
  fi

  prompt_make_command_and_run_now
  prompt_entertainment_choice

  FABRIC_RUN_MODS_DIR="$FABRIC_CLONE_DIR/Minecrak/run/mods"
  FABRIC_RUN_SAVES_DIR="$FABRIC_CLONE_DIR/Minecrak/run/saves"

  echo
  echo "Minecrak mods dir:  $FABRIC_RUN_MODS_DIR"
  echo "Minecrak saves dir: $FABRIC_RUN_SAVES_DIR"
  echo

  # Fun URL
  if [ "$OPEN_FUN" = "Yes" ]; then
    echo -e "${GREEN}[INFO] Opening entertainment URL while we download...${NC}"
    open "$ENTERTAINMENT_URL" >/dev/null 2>&1 &
  fi

  # 1) Clone
  echo -e "${GREEN}[1/7] Cloning Fabric example mod into '$FABRIC_PROJECT_DIR'...${NC}"
  CREATED_PROJECT_DIR="$FABRIC_PROJECT_DIR"
  git clone "$FABRIC_EXAMPLE_REPO" "$FABRIC_PROJECT_DIR"
  cd "$FABRIC_PROJECT_DIR"
  echo -e "${GREEN}[DEBUG] Now in $FABRIC_PROJECT_DIR${NC}"

  # Simplified: we assume the example mod already has run config; extra mods are just copied
  mkdir -p dev-mods run/mods

  # Example Mod Menu download (you already had this)
  echo -e "${GREEN}[2/7] Downloading Mod Menu into dev-mods/, run/mods/, and Minecrak run/mods/...${NC}"
  curl -L -o dev-mods/modmenu.jar "https://cdn.modrinth.com/data/mOgUt4GM/versions/latest/download"
  cp dev-mods/modmenu.jar run/mods/ || true
  mkdir -p "$FABRIC_RUN_MODS_DIR"
  cp dev-mods/modmenu.jar "$FABRIC_RUN_MODS_DIR" || true

  # Copy user extra mods
  if [ "$FABRIC_MODS_CHOICE" = "Yes" ] && [ -n "$FABRIC_EXTRA_MODS" ]; then
    while IFS= read -r modpath; do
      [ -z "$modpath" ] && continue
      echo -e "${GREEN}[DEBUG] Copying extra mod: $modpath${NC}"
      cp "$modpath" run/mods/ || true
      cp "$modpath" "$FABRIC_RUN_MODS_DIR" || true
    done <<< "$FABRIC_EXTRA_MODS"
  fi

  # Build + run
  echo -e "${GREEN}[3/7] Running ./gradlew build ...${NC}"
  ./gradlew build

  echo -e "${GREEN}[4/7] Running ./gradlew runClient ...${NC}"
  set +e
  ./gradlew runClient
  RUN_EXIT=$?
  set -e

  if [ $RUN_EXIT -ne 0 ]; then
    echo
    echo -e "${GREEN}[WARN] Fabric dev client exited with non-zero code ($RUN_EXIT). This is usually a mod crash or dependency issue; check the log above.${NC}"
    exit 1
  fi

  # Optional helper
  if [ "$MAKE_COMMAND" = "Yes" ]; then
    echo -e "${GREEN}[5/7] Creating runClient helper script for Fabric...${NC}"
    RUN_CMD_PATH="$HOME/run_minecrak_fabric.sh"
    cat > "$RUN_CMD_PATH" <<EOF
#!/usr/bin/env bash
cd "$FABRIC_PROJECT_DIR"
./gradlew runClient
EOF
    chmod +x "$RUN_CMD_PATH"
    echo "Created: $RUN_CMD_PATH"
  fi

  CREATED_PROJECT_DIR=""
  echo
  echo -e "${GREEN}=== Fabric setup complete ===${NC}"
  echo "Project created at: $FABRIC_PROJECT_DIR"
}

# ====== NEOFORGE FLOW ======

run_neoforge_setup() {
  echo
  echo -e "${GREEN}=== NeoForge dev setup (MDK clone) ===${NC}"

  # Version: free text, build MDK URL
  read -r -p "NeoForge Minecraft version (e.g. 1.21.1, 1.21.11) [$DEFAULT_NEO_VERSION]: " NEO_VERSION_CHOICE
  NEO_VERSION_CHOICE="${NEO_VERSION_CHOICE:-$DEFAULT_NEO_VERSION}"
  NEO_MDK_REPO="https://github.com/NeoForgeMDKs/MDK-${NEO_VERSION_CHOICE}-NeoGradle.git"

  prompt_clone_dir_and_project_name "$DEFAULT_NEO_PROJECT_NAME" "NEOPROJECT_NAME"
  prompt_extra_mods_list
  NEO_MODS_CHOICE="$MODS_CHOICE"
  NEO_EXTRA_MODS="$EXTRA_MODS"

  echo
  echo -e "${GREEN}=== Summary (NeoForge) ===${NC}"
  echo "Minecraft version:  $NEO_VERSION_CHOICE"
  echo "MDK repo:           $NEO_MDK_REPO"
  echo "Project name:       $NEOPROJECT_NAME"
  echo "Clone directory:    $NEO_CLONE_DIR"
  echo "Full project path:  $NEO_PROJECT_DIR"
  echo "Extra mods choice:  $NEO_MODS_CHOICE"
  [ "$NEO_MODS_CHOICE" = "Yes" ] && echo "Extra mods list:    (paths shown below):" && printf "%s" "$NEO_EXTRA_MODS"
  echo "========================"

  if [ -d "$NEO_PROJECT_DIR" ]; then
    echo
    echo -e "${GREEN}Directory '$NEO_PROJECT_DIR' already exists, aborting to avoid overwrite.${NC}"
    exit 1
  fi

  prompt_make_command_and_run_now
  prompt_entertainment_choice

  # Fun URL
  if [ "$OPEN_FUN" = "Yes" ]; then
    echo
    echo -e "${GREEN}[INFO] Opening entertainment URL while we download...${NC}"
    open "$ENTERTAINMENT_URL" >/dev/null 2>&1 &
  fi

  echo
  echo -e "${GREEN}[STEP 1/4] Cloning NeoForge MDK...${NC}"
  CREATED_PROJECT_DIR="$NEO_PROJECT_DIR"
  git clone "$NEO_MDK_REPO" "$NEO_PROJECT_DIR"
  cd "$NEO_PROJECT_DIR"
  echo -e "${GREEN}[DEBUG] Now in $NEO_PROJECT_DIR${NC}"

  # Ensure run dir; most MDKs use 'run' as gameDirectory
  NEO_RUN_DIR="run"
  mkdir -p "$NEO_RUN_DIR/mods"

  # Copy extra mods into run/mods
  if [ "$NEO_MODS_CHOICE" = "Yes" ] && [ -n "$NEO_EXTRA_MODS" ]; then
    echo
    echo -e "${GREEN}[STEP 2/4] Copying NeoForge extra mods into $NEO_RUN_DIR/mods ...${NC}"
    while IFS= read -r modpath; do
      [ -z "$modpath" ] && continue
      echo -e "${GREEN}[DEBUG] Copying extra mod: $modpath${NC}"
      cp "$modpath" "$NEO_RUN_DIR/mods/" || true
    done <<< "$NEO_EXTRA_MODS"
  else
    echo
    echo -e "${GREEN}[STEP 2/4] Skipping extra mods...${NC}"
  fi

  # Optional helper script
  if [ "$MAKE_COMMAND" = "Yes" ]; then
    echo
    echo -e "${GREEN}[STEP 3/4] Creating runClient helper script for NeoForge...${NC}"
    RUN_CMD_PATH="$HOME/run_minecrak_neo.sh"
    cat > "$RUN_CMD_PATH" <<EOF
#!/usr/bin/env bash
cd "$NEO_PROJECT_DIR"
./gradlew runClient
EOF
    chmod +x "$RUN_CMD_PATH"
    echo "Created: $RUN_CMD_PATH"
  else
    echo
    echo -e "${GREEN}[STEP 3/4] Skipping runClient helper script...${NC}"
  fi

  echo
  echo -e "${GREEN}[STEP 4/4] Running ./gradlew runClient (first run may download a lot)...${NC}"
  set +e
  ./gradlew runClient
  RUN_EXIT=$?
  set -e

  if [ $RUN_EXIT -ne 0 ]; then
    echo
    echo -e "${GREEN}[WARN] NeoForge dev client exited with non-zero code ($RUN_EXIT). This is usually a mod crash or dependency issue; check the log above.${NC}"
    exit 1
  fi

  CREATED_PROJECT_DIR=""
  echo
  echo -e "${GREEN}=== NeoForge setup complete ===${NC}"
  echo "Project created at: $NEO_PROJECT_DIR"
}

# ====== MAIN LOOP ======

main_once() {
  prompt_loader_choice

  if [ "$LOADER" = "Fabric" ]; then
    run_fabric_setup
  else
    run_neoforge_setup
  fi
}

while true; do
  main_once

  echo
  echo "Press Enter to run the setup again, or type anything then Enter to quit."
  read -r retry
  if [ -n "$retry" ]; then
    echo "Exiting."
    break
  fi
done
