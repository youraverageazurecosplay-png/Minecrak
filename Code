#!/usr/bin/env bash
set -euo pipefail

FABRIC_URL="https://raw.githubusercontent.com/youraverageazurecosplay-png/Minecrak/refs/heads/main/Fabrik"
NEO_URL="https://raw.githubusercontent.com/youraverageazurecosplay-png/Minecrak/refs/heads/main/NeoForg"

choose_loader_gui() {
  local choice
  choice="$(osascript <<'EOF'
set options to {"Fabric", "NeoForge", "Quit"}
tell application "System Events"
  activate
  set theChoice to choose from list options with title "Minecrak Setup" with prompt "Choose loader:" default items {"Fabric"}
end tell
if theChoice is false then
  return "Quit"
else
  return item 1 of theChoice
end if
EOF
)"
  echo "$choice"
}

run_remote() {
  url="$1"
  tmp="$(mktemp)"
  curl -fsSL "$url" -o "$tmp"
  chmod +x "$tmp"
  "$tmp"
  rm -f "$tmp"
}

main() {
  loader="$(choose_loader_gui)"
  case "$loader" in
    "Fabric")   run_remote "$FABRIC_URL" ;;
    "NeoForge") run_remote "$NEO_URL" ;;
    *)          exit 0 ;;
  esac
}

main
