#!/usr/bin/env bash
set -euo pipefail

GREEN="\033[0;32m"
NC="\033[0m"

FABRIC_URL="https://raw.githubusercontent.com/youraverageazurecosplay-png/Minecrak/refs/heads/main/Fabrik"
NEO_URL="https://raw.githubusercontent.com/youraverageazurecosplay-png/Minecrak/refs/heads/main/NeoForg"

prompt_loader_choice() {
  echo -e "${GREEN}=== Minecrak Dev Setup ===${NC}"
  echo
  echo "Which loader do you want to set up?"
  select opt in "Fabric" "NeoForge" "Quit"; do
    case "$opt" in
      "Fabric") LOADER="Fabric"; break ;;
      "NeoForge") LOADER="NeoForge"; break ;;
      "Quit") LOADER="Quit"; break ;;
      *) echo "Invalid choice."; ;;
    esac
  done
}

run_remote() {
  url="$1"
  tmp="$(mktemp)"
  curl -fsSL "$url" -o "$tmp"
  chmod +x "$tmp"
  "$tmp"
  rm -f "$tmp"
}

main() {
  prompt_loader_choice
  case "$LOADER" in
    "Fabric")   run_remote "$FABRIC_URL" ;;
    "NeoForge") run_remote "$NEO_URL" ;;
    "Quit")     echo "Bye."; exit 0 ;;
  esac
}

main
