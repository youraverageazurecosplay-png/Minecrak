#!/usr/bin/env bash
set -euo pipefail

GREEN="\033[0;32m"
NC="\033[0m"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
FABRIC_LOCAL="$SCRIPT_DIR/Fabrik"
NEO_LOCAL="$SCRIPT_DIR/NeoForg"

FABRIC_URL="https://raw.githubusercontent.com/youraverageazurecosplay-png/Minecrak/refs/heads/main/Fabrik"
NEO_URL="https://raw.githubusercontent.com/youraverageazurecosplay-png/Minecrak/refs/heads/main/NeoForg"

prompt_loader_choice() {
  echo -e "${GREEN}=== Minecrak Dev Setup ===${NC}"
  echo
  echo "What do you want to do?"
  select opt in "Fabric" "NeoForge" "Install tools (Java/Gradle)" "Quit"; do
    case "$opt" in
      "Fabric") LOADER="Fabric"; break ;;
      "NeoForge") LOADER="NeoForge"; break ;;
      "Install tools (Java/Gradle)") LOADER="Tools"; break ;;
      "Quit") LOADER="Quit"; break ;;
      *) echo "Invalid choice."; ;;
    esac
  done
}

ensure_local_copy() {
  url="$1"
  local_path="$2"
  curl -fsSL "$url" -o "$local_path"
  chmod +x "$local_path"
}

install_tools() {
  echo -e "${GREEN}=== Installing required tools ===${NC}"
  echo

  if ! command -v java >/dev/null 2>&1; then
    echo "Java not found."
    if command -v brew >/dev/null 2>&1; then
      echo "Installing Temurin JDK via Homebrew..."
      brew install --cask temurin
    else
      echo "Homebrew not found."
      echo "Please install Java manually from: https://adoptium.net"
    fi
  else
    echo "Java is already installed."
  fi

  if ! command -v gradle >/dev/null 2>&1; then
    echo
    echo "Gradle not found."
    if command -v brew >/dev/null 2>&1; then
      echo "Installing Gradle via Homebrew..."
      brew install gradle
    else
      echo "Homebrew not found."
      echo "Gradle wrapper (./gradlew) will still work in each project."
      echo "If you want system Gradle, install manually from: https://gradle.org/install/"
    fi
  else
    echo
    echo "Gradle is already installed."
  fi

  echo
  echo -e "${GREEN}Tool check complete.${NC}"
}

main() {
  prompt_loader_choice
  case "$LOADER" in
    "Fabric")
      ensure_local_copy "$FABRIC_URL" "$FABRIC_LOCAL"
      "$FABRIC_LOCAL"
      ;;
    "NeoForge")
      ensure_local_copy "$NEO_URL" "$NEO_LOCAL"
      "$NEO_LOCAL"
      ;;
    "Tools")
      install_tools
      ;;
    "Quit")
      echo "Bye."
      exit 0
      ;;
  esac
}

main
