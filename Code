# ====== MAIN LOOP ======

main_once() {
  prompt_loader_choice

  if [ "$LOADER" = "Fabric" ]; then
    run_fabric_setup
  else
    run_neoforge_setup
  fi
}

while true; do
  main_once

  echo
  echo "Press Enter to run the setup again, or type anything then Enter to quit."
  read -r retry
  if [ -n "$retry" ]; then
    echo "Exiting."
    break
  fi
done
