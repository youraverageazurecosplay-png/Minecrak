#!/usr/bin/env bash
set -euo pipefail

DEFAULT_CLONE_DIR="$HOME"
DEFAULT_NEO_PROJECT_NAME="Minecrak Neo"
DEFAULT_NEO_VERSION="1.21.1"
ENTERTAINMENT_URL="https://www.youtube.com"

GREEN="\033[0;32m"
NC="\033[0m"

prompt_clone_dir_and_project_name() {
  local default_name="$1"

  echo
  read -r -p "Project name [$default_name]: " pname
  pname="${pname:-$default_name}"

  echo
  echo "Where should the project folder be created?"
  echo "1) Use default (home folder: $DEFAULT_CLONE_DIR)"
  echo "2) Choose a custom directory"
  while true; do
    read -r -p "Select 1 or 2 [1]: " clone_choice
    clone_choice="${clone_choice:-1}"
    case "$clone_choice" in
      1)
        CLONE_DIR="$DEFAULT_CLONE_DIR"
        break
        ;;
      2)
        while true; do
          read -r -p "Enter custom clone directory path: " custom_dir
          if [ -d "$custom_dir" ]; then
            CLONE_DIR="$custom_dir"
            break
          else
            echo "Directory '$custom_dir' does not exist. Try again."
          fi
        done
        break
        ;;
      *)
        echo "Invalid choice, enter 1 or 2."
        ;;
    esac
  done
  CLONE_DIR="${CLONE_DIR%/}"
  NEOPROJECT_NAME="$pname"
  NEO_CLONE_DIR="$CLONE_DIR"
  NEO_PROJECT_DIR="$NEO_CLONE_DIR/$NEOPROJECT_NAME"
}

prompt_extra_mods_list() {
  echo
  echo "Do you want to add extra mods to the dev instance?"
  select opt in "No" "Yes"; do
    case "$opt" in
      "No")  NEO_MODS_CHOICE="No";  NEO_EXTRA_MODS=""; break ;;
      "Yes") NEO_MODS_CHOICE="Yes"; break ;;
      *) echo "Invalid choice."; ;;
    esac
  done

  if [ "$NEO_MODS_CHOICE" = "Yes" ]; then
    echo
    echo "Paste full paths to mods (jars), one per line."
    echo "End with an empty line."
    NEO_EXTRA_MODS=""
    while IFS= read -r line; do
      [ -z "$line" ] && break
      NEO_EXTRA_MODS+="${line}"$'\n'
    done
  fi
}

prompt_import_config() {
  echo
  echo "Do you want to import an existing config folder into this dev instance?"
  select opt in "No" "Yes"; do
    case "$opt" in
      "No")  IMPORT_CONFIG_CHOICE="No";  IMPORT_CONFIG_PATH=""; break ;;
      "Yes") IMPORT_CONFIG_CHOICE="Yes"; break ;;
      *) echo "Invalid choice."; ;;
    esac
  done

  if [ "$IMPORT_CONFIG_CHOICE" = "Yes" ]; then
    while true; do
      echo
      echo "Enter the full path to the existing config folder (e.g. your .minecraft/config):"
      read -r IMPORT_CONFIG_PATH
      if [ -d "$IMPORT_CONFIG_PATH" ]; then
        break
      else
        echo "Directory '$IMPORT_CONFIG_PATH' does not exist. Try again."
      fi
    done
  fi
}

import_config_into() {
  local target_config_dir="$1"
  if [ "$IMPORT_CONFIG_CHOICE" = "Yes" ] && [ -n "${IMPORT_CONFIG_PATH:-}" ]; then
    echo
    echo -e "${GREEN}[CONFIG] Importing configs from '$IMPORT_CONFIG_PATH' into '$target_config_dir' ...${NC}"
    mkdir -p "$target_config_dir"
    cp -R "$IMPORT_CONFIG_PATH"/. "$target_config_dir"/ 2>/dev/null || true
  fi
}

create_neo_uninstaller() {
  local dir="$1"
  local script="$dir/uninstall-neoforge.command"
  cat > "$script" <<EOF
#!/usr/bin/env bash
echo "This will delete the NeoForge project at:"
echo "  $dir"
read -r -p "Type 'DELETE' to confirm: " ans
if [ "\$ans" = "DELETE" ]; then
  rm -rf "$dir"
  echo "Deleted."
else
  echo "Cancelled."
fi
EOF
  chmod +x "$script"
}

main() {
  echo -e "${GREEN}=== NeoForge Dev Setup (ONLY NeoForge, no Fabric) ===${NC}"

  read -r -p "NeoForge Minecraft version (e.g. 1.21.1, 1.21.11) [$DEFAULT_NEO_VERSION]: " NEO_VERSION_CHOICE
  NEO_VERSION_CHOICE="${NEO_VERSION_CHOICE:-$DEFAULT_NEO_VERSION}"
  NEO_MDK_REPO="https://github.com/NeoForgeMDKs/MDK-${NEO_VERSION_CHOICE}-NeoGradle.git"

  prompt_clone_dir_and_project_name "$DEFAULT_NEO_PROJECT_NAME"
  prompt_extra_mods_list
  prompt_import_config

  echo
  echo -e "${GREEN}=== Summary (NeoForge) ===${NC}"
  echo "Minecraft version:  $NEO_VERSION_CHOICE"
  echo "MDK repo:           $NEO_MDK_REPO"
  echo "Project name:       $NEOPROJECT_NAME"
  echo "Clone directory:    $NEO_CLONE_DIR"
  echo "Full project path:  $NEO_PROJECT_DIR"
  echo "Extra mods choice:  $NEO_MODS_CHOICE"
  [ "$NEO_MODS_CHOICE" = "Yes" ] && printf "Extra mods list:\n%s" "$NEO_EXTRA_MODS"
  echo "Import config:      $IMPORT_CONFIG_CHOICE"
  [ "$IMPORT_CONFIG_CHOICE" = "Yes" ] && echo "Config source:      $IMPORT_CONFIG_PATH"
  echo "========================"

  if [ -d "$NEO_PROJECT_DIR" ]; then
    echo
    echo -e "${GREEN}Directory '$NEO_PROJECT_DIR' already exists, aborting to avoid overwrite.${NC}"
    exit 1
  fi

  echo
  echo "Open something entertaining in your browser while it downloads? (y/N)"
  read -r open_fun
  if [ "$open_fun" = "y" ] || [ "$open_fun" = "Y" ]; then
    open "$ENTERTAINMENT_URL" >/dev/null 2>&1 || true
  fi

  echo
  echo -e "${GREEN}[1/4] Cloning NeoForge MDK into '$NEO_PROJECT_DIR'...${NC}"
  git clone "$NEO_MDK_REPO" "$NEO_PROJECT_DIR"
  cd "$NEO_PROJECT_DIR"

  if grep -q "neoForge {" build.gradle; then
    echo -e "${GREEN}[2/4] Patching build.gradle gameDirectory to 'runs/client'...${NC}"
    sed -i.bak '
      /neoForge\s*{/,/}/ {
        /runs\s*{/,/}/ {
          /client\s*{/,/}/ {
            /gameDirectory/d
            /client\s*{/a\
                \ \ \ \ \ \ \ \ gameDirectory = project.file("runs/client")
          }
        }
      }
    ' build.gradle
  fi

  NEO_RUN_DIR="runs/client"
  mkdir -p "$NEO_RUN_DIR/mods"
  NEO_CONFIG_DIR="$NEO_RUN_DIR/config"

  if [ "$NEO_MODS_CHOICE" = "Yes" ] && [ -n "$NEO_EXTRA_MODS" ]; then
    echo
    echo -e "${GREEN}[3/4] Copying NeoForge extra mods into $NEO_RUN_DIR/mods ...${NC}"
    while IFS= read -r modpath; do
      [ -z "$modpath" ] && continue
      echo "Copying: $modpath"
      cp "$modpath" "$NEO_RUN_DIR/mods/" || true
    done <<< "$NEO_EXTRA_MODS"
  fi

  import_config_into "$NEO_CONFIG_DIR"

  echo
  echo -e "${GREEN}[3.5/4] Creating start-neoforge.command helper in the project root...${NC}"
  START_CMD="$NEO_PROJECT_DIR/start-neoforge.command"
  cat > "$START_CMD" <<EOF
#!/usr/bin/env bash
cd "\$(dirname "\$0")"
./gradlew runClient
EOF
  chmod +x "$START_CMD"
  echo "Created: $START_CMD"

  echo
  echo -e "${GREEN}[4/4] Creating NeoForge uninstaller...${NC}"
  create_neo_uninstaller "$NEO_PROJECT_DIR"

  echo
  echo -e "${GREEN}=== NeoForge setup complete ===${NC}"
  echo "Project:      $NEO_PROJECT_DIR"
  echo "Mods go in:   $NEO_PROJECT_DIR/runs/client/mods"
  echo "Config goes:  $NEO_PROJECT_DIR/runs/client/config"
  echo "To run:       double-click $NEO_PROJECT_DIR/start-neoforge.command"
  echo "To uninstall: double-click $NEO_PROJECT_DIR/uninstall-neoforge.command"
}

main
