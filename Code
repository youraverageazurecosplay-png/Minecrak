#!/usr/bin/env bash
set -euo pipefail

GREEN="\033[0;32m"
NC="\033[0m"
DEFAULT_CLONE_DIR="$HOME"

prompt_loader_choice() {
  echo -e "${GREEN}=== Minecrak Dev Setup ===${NC}"
  echo
  echo "Which loader do you want to set up?"
  select opt in "Fabric" "NeoForge" "Quit"; do
    case "$opt" in
      "Fabric") LOADER="Fabric"; break ;;
      "NeoForge") LOADER="NeoForge"; break ;;
      "Quit") LOADER="Quit"; break ;;
      *) echo "Invalid choice."; ;;
    esac
  done
}

run_fabric_setup() {
  local DEFAULT_FABRIC_PROJECT_NAME="Minecrak Fabric"
  local DEFAULT_FABRIC_VERSION="1.21.1"
  local FABRIC_EXAMPLE_REPO="https://github.com/FabricMC/fabric-example-mod"

  echo -e "${GREEN}=== Fabric Dev Setup ===${NC}"
  read -r -p "Minecraft version for Fabric [$DEFAULT_FABRIC_VERSION]: " FABRIC_MC_VERSION
  FABRIC_MC_VERSION="${FABRIC_MC_VERSION:-$DEFAULT_FABRIC_VERSION}"
  echo
  read -r -p "Fabric project name [$DEFAULT_FABRIC_PROJECT_NAME]: " FABRIC_PROJECT_NAME
  FABRIC_PROJECT_NAME="${FABRIC_PROJECT_NAME:-$DEFAULT_FABRIC_PROJECT_NAME}"
  echo
  echo "Fabric project base directory (default: $DEFAULT_CLONE_DIR)"
  read -r -p "Path (ENTER for default): " FABRIC_CLONE_DIR
  FABRIC_CLONE_DIR="${FABRIC_CLONE_DIR:-$DEFAULT_CLONE_DIR}"
  FABRIC_CLONE_DIR="${FABRIC_CLONE_DIR%/}"
  FABRIC_PROJECT_DIR="$FABRIC_CLONE_DIR/$FABRIC_PROJECT_NAME"

  echo
  echo -e "${GREEN}[F-1/3] Cloning Fabric example mod to '$FABRIC_PROJECT_DIR'...${NC}"
  git clone "$FABRIC_EXAMPLE_REPO" "$FABRIC_PROJECT_DIR"
  cd "$FABRIC_PROJECT_DIR"
  mkdir -p run/mods run/config
  echo -e "${GREEN}[F-2/3] Running ./gradlew build...${NC}"
  ./gradlew build || true
  echo -e "${GREEN}[F-3/3] Creating uninstall-fabric.command...${NC}"
  cat > uninstall-fabric.command <<EOF
#!/usr/bin/env bash
echo "This will delete the Fabric project at:"
echo " $FABRIC_PROJECT_DIR"
read -r -p "Type 'DELETE' to confirm: " ans
if [ "\$ans" = "DELETE" ]; then
  rm -rf "$FABRIC_PROJECT_DIR"
  echo "Deleted."
else
  echo "Cancelled."
fi
EOF
  chmod +x uninstall-fabric.command
  echo
  echo -e "${GREEN}=== Fabric setup complete ===${NC}"
  echo "Project: $FABRIC_PROJECT_DIR"
  echo "Run client: cd \"$FABRIC_PROJECT_DIR\" && ./gradlew runClient"
}

run_neoforge_setup() {
  local DEFAULT_NEO_PROJECT_NAME="Minecrak Neo"
  local DEFAULT_NEO_VERSION="1.21.1"

  echo -e "${GREEN}=== NeoForge Dev Setup ===${NC}"
  read -r -p "NeoForge Minecraft version [$DEFAULT_NEO_VERSION]: " NEO_VERSION_CHOICE
  NEO_VERSION_CHOICE="${NEO_VERSION_CHOICE:-$DEFAULT_NEO_VERSION}"
  local NEO_MDK_REPO="https://github.com/NeoForgeMDKs/MDK-${NEO_VERSION_CHOICE}-NeoGradle.git"
  echo
  read -r -p "NeoForge project name [$DEFAULT_NEO_PROJECT_NAME]: " NEO_PROJECT_NAME
  NEO_PROJECT_NAME="${NEO_PROJECT_NAME:-$DEFAULT_NEO_PROJECT_NAME}"
  echo
  echo "NeoForge project base directory (default: $DEFAULT_CLONE_DIR)"
  read -r -p "Path (ENTER for default): " NEO_CLONE_DIR
  NEO_CLONE_DIR="${NEO_CLONE_DIR:-$DEFAULT_CLONE_DIR}"
  NEO_CLONE_DIR="${NEO_CLONE_DIR%/}"
  NEO_PROJECT_DIR="$NEO_CLONE_DIR/$NEO_PROJECT_NAME"

  echo
  echo -e "${GREEN}[N-1/4] Cloning NeoForge MDK to '$NEO_PROJECT_DIR'...${NC}"
  git clone "$NEO_MDK_REPO" "$NEO_PROJECT_DIR"
  cd "$NEO_PROJECT_DIR"

  sed -i.bak '/neoForge {/,/}/ {
    /runs {/,/}/ {
      /client {/,/}/ {
        /gameDirectory/ d
        /client {/a\
          gameDirectory = project.file("runs/client")
      }
    }
  }' build.gradle

  local NEO_RUN_DIR="runs/client"
  mkdir -p "$NEO_RUN_DIR/mods" "$NEO_RUN_DIR/config"

  echo -e "${GREEN}[N-2/4] Creating start-neoforge.command...${NC}"
  cat > start-neoforge.command <<EOF
#!/usr/bin/env bash
cd "\$(dirname "\$0")"
./gradlew runClient
EOF
  chmod +x start-neoforge.command

  echo -e "${GREEN}[N-3/4] Creating uninstall-neoforge.command...${NC}"
  cat > uninstall-neoforge.command <<EOF
#!/usr/bin/env bash
echo "This will delete the NeoForge project at:"
echo " $NEO_PROJECT_DIR"
read -r -p "Type 'DELETE' to confirm: " ans
if [ "\$ans" = "DELETE" ]; then
  rm -rf "$NEO_PROJECT_DIR"
  echo "Deleted."
else
  echo "Cancelled."
fi
EOF
  chmod +x uninstall-neoforge.command

  echo
  echo -e "${GREEN}=== NeoForge setup complete ===${NC}"
  echo "Project: $NEO_PROJECT_DIR"
  echo "Mods: $NEO_PROJECT_DIR/runs/client/mods"
  echo "Config: $NEO_PROJECT_DIR/runs/client/config"
  echo "Run client: double-click start-neoforge.command"
}

main() {
  prompt_loader_choice
  case "$LOADER" in
    "Fabric") run_fabric_setup ;;
    "NeoForge") run_neoforge_setup ;;
    "Quit") echo "Bye."; exit 0 ;;
  esac
}

main
