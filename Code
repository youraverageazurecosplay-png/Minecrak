#!/usr/bin/env bash
set -euo pipefail

DEFAULT_CLONE_DIR="$HOME"
DEFAULT_PROJECT_NAME="Minecrak Neo"
DEFAULT_NEO_VERSION="1.21.11"
DEFAULT_MDK_REPO="https://github.com/NeoForgeMDKs/MDK-1.21.11-NeoGradle.git"

CREATED_PROJECT_DIR=""

cleanup() {
  if [ -n "${CREATED_PROJECT_DIR:-}" ] && [ -d "$CREATED_PROJECT_DIR" ]; then
    echo
    echo "[CLEANUP] Removing incomplete project directory:"
    echo "  $CREATED_PROJECT_DIR"
    rm -rf "$CREATED_PROJECT_DIR"
  fi
}
trap cleanup EXIT

prompt_project_settings() {
  echo "=== Minecrak Dev Setup ==="
  echo

  read -r -p "Project name [$DEFAULT_PROJECT_NAME]: " NEOPROJECT_NAME
  NEOPROJECT_NAME="${NEOPROJECT_NAME:-$DEFAULT_PROJECT_NAME}"

  echo
  echo "Where should the project folder be created?"
  echo "1) Use default (home folder: $DEFAULT_CLONE_DIR)"
  echo "2) Choose a custom directory"
  while true; do
    read -r -p "Select 1 or 2 [1]: " clone_choice
    clone_choice="${clone_choice:-1}"
    case "$clone_choice" in
      1)
        NEO_CLONE_DIR="$DEFAULT_CLONE_DIR"
        break
        ;;
      2)
        while true; do
          read -r -p "Enter custom clone directory path: " custom_dir
          if [ -d "$custom_dir" ]; then
            NEO_CLONE_DIR="$custom_dir"
            break
          else
            echo "Directory '$custom_dir' does not exist. Try again."
          fi
        done
        break
        ;;
      *)
        echo "Invalid choice, enter 1 or 2."
        ;;
    esac
  done
  NEO_CLONE_DIR="${NEO_CLONE_DIR%/}"

  NEO_PROJECT_DIR="${NEO_CLONE_DIR}/${NEOPROJECT_NAME}"

