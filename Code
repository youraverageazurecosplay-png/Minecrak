run_neoforge_setup() {
  echo
  echo -e "${GREEN}=== NeoForge dev setup (MDK clone) ===${NC}"

  read -r -p "NeoForge Minecraft version (e.g. 1.21.1, 1.21.11) [$DEFAULT_NEO_VERSION]: " NEO_VERSION_CHOICE
  NEO_VERSION_CHOICE="${NEO_VERSION_CHOICE:-$DEFAULT_NEO_VERSION}"
  NEO_MDK_REPO="https://github.com/NeoForgeMDKs/MDK-${NEO_VERSION_CHOICE}-NeoGradle.git"

  prompt_clone_dir_and_project_name "$DEFAULT_NEO_PROJECT_NAME" "NEOPROJECT_NAME"
  prompt_extra_mods_list
  NEO_MODS_CHOICE="$MODS_CHOICE"
  NEO_EXTRA_MODS="$EXTRA_MODS"
  prompt_import_config

  echo
  echo -e "${GREEN}=== Summary (NeoForge) ===${NC}"
  echo "Minecraft version:  $NEO_VERSION_CHOICE"
  echo "MDK repo:           $NEO_MDK_REPO"
  echo "Project name:       $NEOPROJECT_NAME"
  echo "Clone directory:    $NEO_CLONE_DIR"
  echo "Full project path:  $NEO_PROJECT_DIR"
  echo "Extra mods choice:  $NEO_MODS_CHOICE"
  [ "$NEO_MODS_CHOICE" = "Yes" ] && echo "Extra mods list:    (paths shown below):" && printf "%s" "$NEO_EXTRA_MODS"
  echo "Import config:      $IMPORT_CONFIG_CHOICE"
  [ "$IMPORT_CONFIG_CHOICE" = "Yes" ] && echo "Config source:      $IMPORT_CONFIG_PATH"
  echo "========================"

  if [ -d "$NEO_PROJECT_DIR" ]; then
    echo
    echo -e "${GREEN}Directory '$NEO_PROJECT_DIR' already exists, aborting to avoid overwrite.${NC}"
    exit 1
  fi

  prompt_make_command_and_run_now
  prompt_entertainment_choice

  if [ "$OPEN_FUN" = "Yes" ]; then
    echo
    echo -e "${GREEN}[INFO] Opening entertainment URL while we download...${NC}"
    open "$ENTERTAINMENT_URL" >/dev/null 2>&1 &
  fi

  echo
  echo -e "${GREEN}[STEP 1/5] Cloning NeoForge MDK into '$NEO_PROJECT_DIR'...${NC}"
  CREATED_PROJECT_DIR="$NEO_PROJECT_DIR"
  git clone "$NEO_MDK_REPO" "$NEO_PROJECT_DIR"
  cd "$NEO_PROJECT_DIR"
  echo -e "${GREEN}[DEBUG] Now in $NEO_PROJECT_DIR${NC}"

  if grep -q "neoForge {" build.gradle; then
    echo -e "${GREEN}[DEBUG] Patching NeoForge run configuration for external mods...${NC}"
    sed -i.bak '
      /neoForge\s*{/,/}/ {
        /runs\s*{/,/}/ {
          /client\s*{/,/}/ {
            /gameDirectory/d
            /client\s*{/a\
                \ \ \ \ \ \ \ \ gameDirectory = project.file("runs/client")
          }
        }
      }
    ' build.gradle
  fi

  echo
  echo -e "${GREEN}[STEP 2/5] Running ./gradlew runClient once to initialize runs/client ...${NC}"
  set +e
  ./gradlew runClient
  FIRST_RUN_EXIT=$?
  set -e

  if [ $FIRST_RUN_EXIT -ne 0 ]; then
    echo
    echo -e "${GREEN}[WARN] First NeoForge runClient exited with code $FIRST_RUN_EXIT.${NC}"
    echo -e "${GREEN}[WARN] This usually means a crash; check the log above. Aborting setup.${NC}"
    exit 1
  fi

  echo
  echo -e "${GREEN}[INFO] First NeoForge runClient has finished successfully.${NC}"
  echo -e "${GREEN}[INFO] Now copying your extra mods and configs, then starting the client again.${NC}"

  NEO_RUN_DIR="runs/client"
  mkdir -p "$NEO_RUN_DIR/mods"
  NEO_CONFIG_DIR="$NEO_RUN_DIR/config"

  if [ "$NEO_MODS_CHOICE" = "Yes" ] && [ -n "$NEO_EXTRA_MODS" ]; then
    echo
    echo -e "${GREEN}[STEP 3/5] Copying NeoForge extra mods into $NEO_RUN_DIR/mods ...${NC}"
    while IFS= read -r modpath; do
      [ -z "$modpath" ] && continue
      echo -e "${GREEN}[DEBUG] Copying NeoForge mod: $modpath${NC}"
      cp "$modpath" "$NEO_RUN_DIR/mods/" || true
    done <<< "$NEO_EXTRA_MODS"
  else
    echo
    echo -e "${GREEN}[STEP 3/5] Skipping extra mods...${NC}"
  fi

  import_config_into "$NEO_CONFIG_DIR"

  if [ "$MAKE_COMMAND" = "Yes" ]; then
    echo
    echo -e "${GREEN}[STEP 4/5] Creating run-neoforge-client.command helper...${NC}"
    RUN_CMD_PATH="$NEO_PROJECT_DIR/run-neoforge-client.command"
    cat > "$RUN_CMD_PATH" <<EOF
#!/usr/bin/env bash
cd "$NEO_PROJECT_DIR"
./gradlew runClient
EOF
    chmod +x "$RUN_CMD_PATH"
    echo -e "${GREEN}[DEBUG] Created NeoForge .command at $RUN_CMD_PATH${NC}"
  else
    echo
    echo -e "${GREEN}[STEP 4/5] Skipping helper script...${NC}"
  fi

  echo
  echo -e "${GREEN}[STEP 5/5] Running ./gradlew runClient again with mods in place...${NC}"
  set +e
  ./gradlew runClient
  RUN_EXIT=$?
  set -e

  if [ $RUN_EXIT -ne 0 ]; then
    echo
    echo -e "${GREEN}[WARN] NeoForge dev client exited with non-zero code ($RUN_EXIT). Check the log for mod/dependency issues.${NC}"
    exit 1
  fi

  UNINSTALL_CMD="$NEO_PROJECT_DIR/uninstall-minecrak-neo.command"
  cat > "$UNINSTALL_CMD" <<EOF
#!/usr/bin/env bash
echo "This will delete the NeoForge project at:"
echo "  $NEO_PROJECT_DIR"
read -r -p "Type 'DELETE' to confirm: " ans
if [ "\$ans" = "DELETE" ]; then
  rm -rf "$NEO_PROJECT_DIR"
  echo "Deleted."
else
  echo "Cancelled."
fi
EOF
  chmod +x "$UNINSTALL_CMD"

  CREATED_PROJECT_DIR=""
  echo
  echo -e "${GREEN}NeoForge setup complete at: $NEO_PROJECT_DIR${NC}"
  echo "Next time, double-click:"
  echo "  $NEO_PROJECT_DIR/run-neoforge-client.command"
  echo "To uninstall later, double-click:"
  echo "  $UNINSTALL_CMD"
}
