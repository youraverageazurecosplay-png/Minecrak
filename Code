#!/usr/bin/env bash
set -euo pipefail

# =========================
# 0) Ensure swiftDialog is installed
# =========================
install_swiftdialog_if_needed() {
  local dialogApp="/Library/Application Support/Dialog/Dialog.app"
  local dialogBin="/usr/local/bin/dialog"
  local expectedTeamID="PWA5E9TQ59"

  if [ -x "$dialogBin" ] && [ -d "$dialogApp" ]; then
    return 0
  fi

  echo "swiftDialog not found, downloading and installing..."

  local dialogURL
  dialogURL="$(curl --silent --fail "https://api.github.com/repos/bartreardon/swiftDialog/releases/latest" \
    | awk -F '"' '/browser_download_url/ && /pkg/ { print $4; exit }')"

  if [ -z "$dialogURL" ]; then
    echo "Failed to get swiftDialog download URL."
    exit 1
  fi

  local workDirectory tempDirectory
  workDirectory=$( /usr/bin/basename "$0" )
  tempDirectory=$( /usr/bin/mktemp -d "/private/tmp/$workDirectory.XXXXXX" )

  local pkgPath="$tempDirectory/Dialog.pkg"
  /usr/bin/curl --location --silent "$dialogURL" -o "$pkgPath"

  # Verify Team ID (security check)
  local teamID
  teamID=$(/usr/sbin/spctl -a -vv -t install "$pkgPath" 2>&1 | awk '/origin=/ {print $NF}' | tr -d '()')

  if [[ "$expectedTeamID" != "$teamID" ]]; then
    echo "swiftDialog Team ID mismatch. Expected $expectedTeamID, got $teamID"
    exit 1
  fi

  /usr/sbin/installer -pkg "$pkgPath" -target /
  sleep 2

  rm -rf "$tempDirectory"
}

install_swiftdialog_if_needed

DIALOG_BIN="/usr/local/bin/dialog"

# =========================
# 1) Defaults
# =========================
DEFAULT_CLONE_DIR="$HOME"
DEFAULT_PROJECT_NAME="Minecrak Neo"
DEFAULT_NEO_VERSION="1.21.11"
DEFAULT_MDK_REPO="https://github.com/NeoForgeMDKs/MDK-1.21.11-NeoGradle.git"

CREATED_PROJECT_DIR=""
PROGRESS_CMD_FILE="$(mktemp /tmp/minecrak-dialog-progress.XXXXXX)"

cleanup() {
  if [ -n "${CREATED_PROJECT_DIR:-}" ] && [ -d "$CREATED_PROJECT_DIR" ]; then
    echo "Cleaning up project directory: $CREATED_PROJECT_DIR"
    rm -rf "$CREATED_PROJECT_DIR"
  fi
  [ -f "$PROGRESS_CMD_FILE" ] && rm -f "$PROGRESS_CMD_FILE"
}
trap cleanup EXIT

update_progress() {
  for line in "$@"; do
    echo "$line" >> "$PROGRESS_CMD_FILE"
  done
}

# =========================
# 2) Options form GUI
# =========================
run_options_form() {
  "$DIALOG_BIN" \
    --title "Minecrak Dev Setup" \
    --message "Configure your NeoForge dev project." \
    --icon system:hammer \
    --width 600 \
    --height 400 \
    --textfield "Project Name:,$DEFAULT_PROJECT_NAME" \
    --textfield "Clone Folder:,$DEFAULT_CLONE_DIR" \
    --checkbox "Add Extra Mods?,false" \
    --textfield "Mods Folder (if enabled):," \
    --checkbox "Create runClient command in home?,true" \
    --checkbox "Run client after setup?,true" \
    --button1text "Start" \
    --button2text "Cancel" \
    --json
}

FORM_JSON="$(run_options_form)" || exit 1

readarray -t parsed <<<"$(
  /usr/bin/python3 <<EOF
import json, sys
data = json.load(sys.stdin)
fields = data.get("textfield", {})
checks = data.get("checkbox", {})
print(fields.get("Project Name:", "Minecrak Neo"))
print(fields.get("Clone Folder:", "$HOME"))
print("Yes" if checks.get("Add Extra Mods?", False) else "No")
print(fields.get("Mods Folder (if enabled):", ""))
print("Yes" if checks.get("Create runClient command in home?", True) else "No")
print("Yes" if checks.get("Run client after setup?", True) else "No")
EOF
" <<<"$FORM_JSON"
)"

NEOPROJECT_NAME="${parsed[0]}"
NEO_CLONE_DIR="${parsed[1]%/}"
NEO_MODS_CHOICE="${parsed[2]}"
NEO_MODS_FOLDER="${parsed[3]}"
MAKE_COMMAND="${parsed[4]}"
RUN_CLIENT_NOW="${parsed[5]}"
LOADER="NeoForge"

NEO_PROJECT_DIR="${NEO_CLONE_DIR}/${NEOPROJECT_NAME}"

echo "[DEBUG] LOADER: $LOADER"
echo "[DEBUG] NEOPROJECT_NAME: $NEOPROJECT_NAME"
echo "[DEBUG] NEO_CLONE_DIR: $NEO_CLONE_DIR"
echo "[DEBUG] NEO_PROJECT_DIR: $NEO_PROJECT_DIR"
echo "[DEBUG] NEO_MODS_CHOICE: $NEO_MODS_CHOICE"
echo "[DEBUG] NEO_MODS_FOLDER: $NEO_MODS_FOLDER"
echo "[DEBUG] MAKE_COMMAND: $MAKE_COMMAND"
echo "[DEBUG] RUN_CLIENT_NOW: $RUN_CLIENT_NOW"
echo "[DEBUG] NEO_VERSION_CHOICE: $DEFAULT_NEO_VERSION"
echo "[DEBUG] NEO_MDK_REPO: $DEFAULT_MDK_REPO"

if [ -d "$NEO_PROJECT_DIR" ]; then
  "$DIALOG_BIN" \
    --title "Minecrak Dev Setup" \
    --message "Directory '$NEO_PROJECT_DIR' already exists. Aborting to avoid overwrite." \
    --icon system:caution \
    --button1text "OK"
  exit 1
fi

# =========================
# 3) Progress window
# =========================
"$DIALOG_BIN" \
  --title "Minecrak Dev Setup" \
  --message "Setting up project: $NEOPROJECT_NAME" \
  --icon system:hammer \
  --progress \
  --progresstext "Starting..." \
  --commandfile "$PROGRESS_CMD_FILE" &

DIALOG_PID=$!
sleep 0.2

# =========================
# 4) Work with updates
# =========================
CREATED_PROJECT_DIR="$NEO_PROJECT_DIR"

update_progress "progresstext: Cloning MDK..." "progress: 10"
git clone "$DEFAULT_MDK_REPO" "$NEO_PROJECT_DIR"

cd "$NEO_PROJECT_DIR"

if [ "$NEO_MODS_CHOICE" = "Yes" ] && [ -n "$NEO_MODS_FOLDER" ]; then
  if [ -d "$NEO_MODS_FOLDER" ]; then
    update_progress "progresstext: Copying mods..." "progress: 30"
    mkdir -p run/mods
    cp "$NEO_MODS_FOLDER"/*.jar run/mods/ || true
  else
    update_progress "progresstext: Mods folder not found, skipping mods." "progress: 30"
  fi
else
  update_progress "progresstext: Skipping extra mods..." "progress: 30"
fi

if [ "$MAKE_COMMAND" = "Yes" ]; then
  update_progress "progresstext: Creating runClient command..." "progress: 50"
  RUN_CMD_PATH="$HOME/run_minecrak_neo.sh"
  cat > "$RUN_CMD_PATH" <<EOF
#!/usr/bin/env bash
cd "$NEO_PROJECT_DIR"
./gradlew runClient
EOF
  chmod +x "$RUN_CMD_PATH"
fi

update_progress "progresstext: Running initial Gradle tasks..." "progress: 70"
./gradlew --version >/dev/null 2>&1 || true

if [ "$RUN_CLIENT_NOW" = "Yes" ]; then
  update_progress "progresstext: Running dev client..." "progress: 85"
  ./gradlew runClient || true
fi

update_progress "progresstext: Done!" "progress: 100"
sleep 0.5

kill "$DIALOG_PID" 2>/dev/null || true

CREATED_PROJECT_DIR=""

"$DIALOG_BIN" \
  --title "Minecrak Dev Setup" \
  --message "NeoForge setup is complete.\nProject: $NEOPROJECT_NAME" \
  --icon system:checkmark.seal \
  --button1text "OK"

# =========================
# 5) Press Return to restart
# =========================
echo
echo "Press Enter to run the setup again with the same script, or type anything then Enter to quit."
read -r retry
if [ -z "$retry" ]; then
  echo "[DEBUG] Retrying..."
  exec "$0" "$@"
else
  echo "Exiting."
  exit 0
fi
