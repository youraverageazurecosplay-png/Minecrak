#!/usr/bin/env bash
set -euo pipefail

TARGET_MODS_DIR="/Users/ps/TBS/runs/client/mods"
mkdir -p "$TARGET_MODS_DIR"

echo "Drag and drop each mod file here, then press Enter on an empty line when done."
while true; do
  read -r -p "Mod file path (or just Enter to finish): " modpath
  [ -z "$modpath" ] && break
  modpath="${modpath/#\~/$HOME}"
  if [ -f "$modpath" ]; then
    cp "$modpath" "$TARGET_MODS_DIR"
    echo "Copied: $modpath -> $TARGET_MODS_DIR"
  else
    echo "Not a file: $modpath"
  fi
done

echo "All done. Mods are now in: $TARGET_MODS_DIR"
