#!/usr/bin/env bash
set -euo pipefail

DEFAULT_CLONE_DIR="$HOME"
DEFAULT_PROJECT_NAME="Minecrak Neo"
DEFAULT_NEO_VERSION="1.21.11"
DEFAULT_MDK_REPO="https://github.com/NeoForgeMDKs/MDK-1.21.11-NeoGradle.git"

CREATED_PROJECT_DIR=""

cleanup() {
  if [ -n "${CREATED_PROJECT_DIR:-}" ] && [ -d "$CREATED_PROJECT_DIR" ]; then
    echo "Cleaning up project directory:"
    echo "  $CREATED_PROJECT_DIR"
    rm -rf "$CREATED_PROJECT_DIR"
    echo "Cleanup done."
  fi
}
trap cleanup EXIT

run_gui() {
  /usr/bin/osascript <<EOT
set theTitle to "Minecrak Dev Setup"
set thePrompt to "Configure your NeoForge dev project."

-- Project name
set projectName to text returned of (display dialog "Project name:" default answer "$DEFAULT_PROJECT_NAME" with title theTitle)

-- Clone directory (default: home)
set homePOSIX to POSIX path of (path to home folder)
set cloneDir to text returned of (display dialog "Clone directory (where the project folder will be created):" default answer homePOSIX with title theTitle)

-- Mods choice
set modsButtons to {"No Mods", "Select Mods"}
set modsChoiceButton to button returned of (display dialog "Do you want to add extra mods to the dev instance?" buttons modsButtons default button 1 with title theTitle)

set modsChoice to "No"
set modsFolder to ""
if modsChoiceButton is "Select Mods" then
    set modsChoice to "Yes"
    set modsFolder to POSIX path of (choose folder with prompt "Select the folder containing your mods (jars)." default location (path to home folder))
end if

-- Make runClient command?
set cmdButtons to {"No", "Yes"}
set cmdChoiceButton to button returned of (display dialog "Create a 'runClient' shell command in your home folder?" buttons cmdButtons default button 2 with title theTitle)
set makeCommand to "No"
if cmdChoiceButton is "Yes" then set makeCommand to "Yes"

-- Run client after setup?
set runButtons to {"No", "Yes"}
set runClientButton to button returned of (display dialog "Run the dev client after setup?" buttons runButtons default button 2 with title theTitle)
set runClientNow to "No"
if runClientButton is "Yes" then set runClientNow to "Yes"

return "NeoForge|" & projectName & "|" & cloneDir & "|" & modsChoice & "|" & modsFolder & "|" & makeCommand & "|" & runClientNow
EOT
}

GUI_RESULT="$(run_gui)"
IFS='|' read -r LOADER NEOPROJECT_NAME NEO_CLONE_DIR NEO_MODS_CHOICE NEO_MODS_FOLDER MAKE_COMMAND RUN_CLIENT_NOW <<<"$GUI_RESULT"

NEO_CLONE_DIR="${NEO_CLONE_DIR%/}"
NEO_PROJECT_DIR="${NEO_CLONE_DIR}/${NEOPROJECT_NAME}"

echo "[DEBUG] LOADER: $LOADER"
echo "[DEBUG] NEOPROJECT_NAME: $NEOPROJECT_NAME"
echo "[DEBUG] NEO_CLONE_DIR: $NEO_CLONE_DIR"
echo "[DEBUG] NEO_PROJECT_DIR: $NEO_PROJECT_DIR"
echo "[DEBUG] NEO_MODS_CHOICE: $NEO_MODS_CHOICE"
echo "[DEBUG] NEO_MODS_FOLDER: $NEO_MODS_FOLDER"
echo "[DEBUG] MAKE_COMMAND: $MAKE_COMMAND"
echo "[DEBUG] RUN_CLIENT_NOW: $RUN_CLIENT_NOW"
echo "[DEBUG] NEO_VERSION_CHOICE: $DEFAULT_NEO_VERSION"
echo "[DEBUG] NEO_MDK_REPO: $DEFAULT_MDK_REPO"

echo "=== NeoForge dev setup (MDK clone) ==="
echo "Minecraft version:   ${DEFAULT_NEO_VERSION}"
echo "MDK repo:            ${DEFAULT_MDK_REPO}"
echo "Project name:        ${NEOPROJECT_NAME}"
echo "Clone directory:     ${NEO_CLONE_DIR}"
echo "Full project path:   ${NEO_PROJECT_DIR}"
if [ "$NEO_MODS_CHOICE" = "Yes" ]; then
  echo "Mods folder:         ${NEO_MODS_FOLDER}"
else
  echo "Mods folder:         (none)"
fi
echo "======================================"

if [ -d "$NEO_PROJECT_DIR" ]; then
  /usr/bin/osascript <<EOT
display dialog "Directory '$NEO_PROJECT_DIR' already exists. Aborting to avoid overwrite." buttons {"OK"} default button 1 with title "Minecrak Dev Setup"
EOT
  exit 1
fi

CREATED_PROJECT_DIR="$NEO_PROJECT_DIR"

# Show "status" dialogs/notifications as it works
/usr/bin/osascript -e 'display notification "Cloning MDK repository..." with title "Minecrak Dev Setup"'
echo "Cloning MDK..."
git clone "$DEFAULT_MDK_REPO" "$NEO_PROJECT_DIR"

cd "$NEO_PROJECT_DIR"

if [ "$NEO_MODS_CHOICE" = "Yes" ] && [ -n "$NEO_MODS_FOLDER" ]; then
  if [ -d "$NEO_MODS_FOLDER" ]; then
    /usr/bin/osascript -e 'display notification "Copying extra mods..." with title "Minecrak Dev Setup"'
    echo "Copying mods..."
    mkdir -p run/mods
    cp "$NEO_MODS_FOLDER"/*.jar run/mods/ || true
  else
    /usr/bin/osascript -e 'display notification "Mods folder not found, skipping mods." with title "Minecrak Dev Setup"'
    echo "Mods folder not found, skipping mods."
  fi
else
  echo "Skipping extra mods."
fi

if [ "$MAKE_COMMAND" = "Yes" ]; then
  /usr/bin/osascript -e 'display notification "Creating runClient command..." with title "Minecrak Dev Setup"'
  echo "Creating runClient helper script..."
  RUN_CMD_PATH="$HOME/run_minecrak_neo.sh"
  cat > "$RUN_CMD_PATH" <<EOF
#!/usr/bin/env bash
cd "$NEO_PROJECT_DIR"
./gradlew runClient
EOF
  chmod +x "$RUN_CMD_PATH"
fi

/usr/bin/osascript -e 'display notification "Running initial Gradle tasks..." with title "Minecrak Dev Setup"'
echo "Running initial Gradle tasks (gradlew --version)..."
./gradlew --version >/dev/null 2>&1 || true

if [ "$RUN_CLIENT_NOW" = "Yes" ]; then
  /usr/bin/osascript -e 'display notification "Running dev client..." with title "Minecrak Dev Setup"'
  echo "Running dev client..."
  ./gradlew runClient || true
fi

CREATED_PROJECT_DIR=""

/usr/bin/osascript <<EOT
display notification "NeoForge setup is complete." with title "Minecraft Dev Setup" subtitle "Project: $NEOPROJECT_NAME"
EOT

echo
echo "Setup complete for project: $NEOPROJECT_NAME"
echo "Press Enter to run the setup again with the same script, or type anything then Enter to quit."
read -r retry
if [ -z "$retry" ]; then
  echo "[DEBUG] Retrying..."
  exec "$0" "$@"
else
  echo "Exiting."
  exit 0
fi
