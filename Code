#!/usr/bin/env bash
set -euo pipefail

GREEN="\033[0;32m"
NC="\033[0m"

FABRIC_URL="https://raw.githubusercontent.com/YOUR_USER/YOUR_REPO/main/fabric_setup.sh"
NEO_URL="https://raw.githubusercontent.com/YOUR_USER/YOUR_REPO/main/neoforge_setup.sh"

prompt_loader_choice() {
  echo -e "${GREEN}=== Minecrak Master Setup ===${NC}"
  echo
  echo "Which loader do you want to set up?"
  select opt in "Fabric" "NeoForge" "Quit"; do
    case "$opt" in
      "Fabric") LOADER="Fabric"; break ;;
      "NeoForge") LOADER="NeoForge"; break ;;
      "Quit") LOADER="Quit"; break ;;
      *) echo "Invalid choice."; ;;
    esac
  done
}

run_remote() {
  url="$1"
  tmp="$(mktemp)"
  curl -fsSL "$url" -o "$tmp"
  chmod +x "$tmp"
  "$tmp"
  rm -f "$tmp"
}

main() {
  prompt_loader_choice
  case "$LOADER" in
    "Fabric")  run_remote "$FABRIC_URL" ;;
    "NeoForge") run_remote "$NEO_URL" ;;
    "Quit")   echo "Bye."; exit 0 ;;
  esac
}

main
