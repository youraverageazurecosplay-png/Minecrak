#!/usr/bin/env bash
set -euo pipefail

GREEN="\033[0;32m"
NC="\033[0m"
DEFAULT_CLONE_DIR="$HOME"

choose_folder_gui() {
  osascript <<'EOF'
tell application "System Events"
  activate
  set f to choose folder with prompt "Choose the base folder for your Fabric project:"
  return POSIX path of f
end tell
EOF
}

choose_mods_gui() {
  dest="$1"
  mkdir -p "$dest"

  applescript='
    tell application "System Events"
      activate
      set theFiles to choose file with prompt "Choose Fabric mod files (Command/Shift for multiple):" of type {"jar"} with multiple selections allowed
      set thePOSIX to {}
      repeat with f in theFiles
        copy POSIX path of f to the end of thePOSIX
      end repeat
      return thePOSIX as string
    end tell
  '
  if ! selected="$(osascript -e "$applescript" 2>/dev/null)"; then
    return
  fi

  IFS=", " read -r -a files <<< "$selected"
  for f in "${files[@]}"; do
    [ -f "$f" ] && cp "$f" "$dest/"
  done
}

run_fabric_setup() {
  local DEFAULT_FABRIC_PROJECT_NAME="Minecrak Fabric"
  local DEFAULT_FABRIC_VERSION="1.21.11"
  local FABRIC_EXAMPLE_REPO="https://github.com/FabricMC/fabric-example-mod"

  echo -e "${GREEN}=== Fabric Dev Setup ===${NC}"
  read -r -p "Minecraft version for Fabric [$DEFAULT_FABRIC_VERSION]: " FABRIC_MC_VERSION
  FABRIC_MC_VERSION="${FABRIC_MC_VERSION:-$DEFAULT_FABRIC_VERSION}"
  echo
  read -r -p "Fabric project name [$DEFAULT_FABRIC_PROJECT_NAME]: " FABRIC_PROJECT_NAME
  FABRIC_PROJECT_NAME="${FABRIC_PROJECT_NAME:-$DEFAULT_FABRIC_PROJECT_NAME}"
  echo

  echo "Choose Fabric project base directory in a GUI dialog."
  FABRIC_CLONE_DIR="$(choose_folder_gui)"
  FABRIC_CLONE_DIR="${FABRIC_CLONE_DIR%/}"
  FABRIC_PROJECT_DIR="$FABRIC_CLONE_DIR/$FABRIC_PROJECT_NAME"

  echo
  echo -e "${GREEN}[F-1/4] Cloning Fabric example mod to '$FABRIC_PROJECT_DIR'...${NC}"
  git clone "$FABRIC_EXAMPLE_REPO" "$FABRIC_PROJECT_DIR"
  cd "$FABRIC_PROJECT_DIR"

  mkdir -p run/mods run/config
  echo -e "${GREEN}[F-2/4] Choose Fabric mods in a GUI dialog...${NC}"
  choose_mods_gui "run/mods"

  echo -e "${GREEN}[F-3/4] Running ./gradlew build...${NC}"
  ./gradlew build || true

  echo -e "${GREEN}[F-4/4] Creating uninstall-fabric.command...${NC}"
  cat > uninstall-fabric.command <<EOF
#!/usr/bin/env bash
echo "This will delete the Fabric project at:"
echo " $FABRIC_PROJECT_DIR"
read -r -p "Type 'DELETE' to confirm: " ans
if [ "\$ans" = "DELETE" ]; then
  rm -rf "$FABRIC_PROJECT_DIR"
  echo "Deleted."
else
  echo "Cancelled."
fi
EOF
  chmod +x uninstall-fabric.command

  echo
  echo -e "${GREEN}=== Fabric setup complete ===${NC}"
  echo "Project: $FABRIC_PROJECT_DIR"
  echo "Mods:    $FABRIC_PROJECT_DIR/run/mods"
  echo "Config:  $FABRIC_PROJECT_DIR/run/config"
  echo "Run client: cd \"$FABRIC_PROJECT_DIR\" && ./gradlew runClient"
}

run_fabric_setup
