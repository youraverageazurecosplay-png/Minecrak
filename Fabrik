#!/usr/bin/env bash
set -euo pipefail

GREEN="\033[0;32m"
NC="\033[0m"
DEFAULT_CLONE_DIR="$HOME"

run_fabric_setup() {
  local DEFAULT_FABRIC_PROJECT_NAME="Minecrak Fabric"
  local DEFAULT_FABRIC_VERSION="1.21.11"
  local FABRIC_EXAMPLE_REPO="https://github.com/FabricMC/fabric-example-mod"

  echo -e "${GREEN}=== Fabric Dev Setup ===${NC}"
  read -r -p "Minecraft version for Fabric [$DEFAULT_FABRIC_VERSION]: " FABRIC_MC_VERSION
  FABRIC_MC_VERSION="${FABRIC_MC_VERSION:-$DEFAULT_FABRIC_VERSION}"
  echo
  read -r -p "Fabric project name [$DEFAULT_FABRIC_PROJECT_NAME]: " FABRIC_PROJECT_NAME
  FABRIC_PROJECT_NAME="${FABRIC_PROJECT_NAME:-$DEFAULT_FABRIC_PROJECT_NAME}"
  echo
  echo "Fabric project base directory (default: $DEFAULT_CLONE_DIR)"
  read -r -p "Path (ENTER for default): " FABRIC_CLONE_DIR
  FABRIC_CLONE_DIR="${FABRIC_CLONE_DIR:-$DEFAULT_CLONE_DIR}"
  FABRIC_CLONE_DIR="${FABRIC_CLONE_DIR%/}"
  FABRIC_PROJECT_DIR="$FABRIC_CLONE_DIR/$FABRIC_PROJECT_NAME"

  while [ -d "$FABRIC_PROJECT_DIR" ] && [ "$(ls -A "$FABRIC_PROJECT_DIR" 2>/dev/null | wc -l)" -gt 0 ]; do
    echo
    echo "Directory '$FABRIC_PROJECT_DIR' already exists and is not empty."
    echo "What do you want to do?"
    echo "  1) Delete it and recreate"
    echo "  2) Enter a different project name"
    echo "  3) Abort"
    read -r -p "Choice [1/2/3]: " EXIST_CHOICE
    case "$EXIST_CHOICE" in
      1)
        rm -rf "$FABRIC_PROJECT_DIR"
        echo "Deleted '$FABRIC_PROJECT_DIR'."
        ;;
      2)
        read -r -p "New Fabric project name: " FABRIC_PROJECT_NAME
        FABRIC_PROJECT_NAME="${FABRIC_PROJECT_NAME:-$DEFAULT_FABRIC_PROJECT_NAME}"
        FABRIC_PROJECT_DIR="$FABRIC_CLONE_DIR/$FABRIC_PROJECT_NAME"
        ;;
      3)
        echo "Aborting Fabric setup."
        return 1
        ;;
      *)
        echo "Invalid choice."
        ;;
    esac
  done

  echo
  echo -e "${GREEN}[F-1/3] Cloning Fabric example mod to '$FABRIC_PROJECT_DIR'...${NC}"
  git clone "$FABRIC_EXAMPLE_REPO" "$FABRIC_PROJECT_DIR"
  cd "$FABRIC_PROJECT_DIR"

  mkdir -p run/mods run/config

  echo -e "${GREEN}[F-2/3] Running ./gradlew build (you can runClient later)...${NC}"
  ./gradlew build || true

  echo -e "${GREEN}[F-3/3] Creating uninstall-fabric.command...${NC}"
  cat > uninstall-fabric.command <<EOF
#!/usr/bin/env bash
echo "This will delete the Fabric project at:"
echo " $FABRIC_PROJECT_DIR"
read -r -p "Type 'DELETE' to confirm: " ans
if [ "\$ans" = "DELETE" ]; then
  rm -rf "$FABRIC_PROJECT_DIR"
  echo "Deleted."
else
  echo "Cancelled."
fi
EOF
  chmod +x uninstall-fabric.command

  echo
  echo -e "${GREEN}=== Fabric setup complete ===${NC}"
  echo "Project: $FABRIC_PROJECT_DIR"
  echo "Run client: cd \"$FABRIC_PROJECT_DIR\" && ./gradlew runClient"
}

run_fabric_setup
