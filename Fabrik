#!/usr/bin/env bash
set -uo pipefail

GREEN="\033[0;32m"
NC="\033[0m"
DEFAULT_CLONE_DIR="$HOME"

move_mods_and_config() {
  SOURCE="$1/mods"
  TARGET_MODS="$1/run/mods"
  TARGET_CONFIG="$1/run/config"

  mkdir -p "$TARGET_MODS"
  mkdir -p "$TARGET_CONFIG"

  # Move mod jars
  if [ -d "$SOURCE" ]; then
    find "$SOURCE" -maxdepth 1 -type f -name '*.jar' -exec mv {} "$TARGET_MODS"/ \;
  fi

  # Move config folder
  if [ -d "$SOURCE/config" ]; then
    echo "Importing config folder..."
    rm -rf "$TARGET_CONFIG"
    mv "$SOURCE/config" "$TARGET_CONFIG"
  fi
}

close_finder_window() {
  osascript <<EOF 2>/dev/null || true
tell application "Finder"
    try
        set targetPath to POSIX file "$1" as alias
        repeat with w in windows
            if (target of w as alias) is targetPath then
                close w
            end if
        end repeat
    end try
end tell
EOF
}

run_fabric_setup() {

  DEFAULT_PROJECT_NAME="Minecrak Fabric"
  DEFAULT_MC_VERSION="1.21.1"

  echo -e "${GREEN}=== Fabric Dev Setup ===${NC}"

  read -r -p "Minecraft version [$DEFAULT_MC_VERSION]: " MC_VERSION
  MC_VERSION="${MC_VERSION:-$DEFAULT_MC_VERSION}"

  FABRIC_REPO="https://github.com/FabricMC/fabric-example-mod.git"

  echo
  read -r -p "Fabric project name [$DEFAULT_PROJECT_NAME]: " PROJECT_NAME
  PROJECT_NAME="${PROJECT_NAME:-$DEFAULT_PROJECT_NAME}"

  echo
  echo "Project base directory (default: $DEFAULT_CLONE_DIR)"
  read -r -p "Path (ENTER for default): " CLONE_DIR
  CLONE_DIR="${CLONE_DIR:-$DEFAULT_CLONE_DIR}"
  CLONE_DIR="${CLONE_DIR%/}"

  PROJECT_DIR="$CLONE_DIR/$PROJECT_NAME"

  echo
  echo -e "${GREEN}[1/6] Cloning Fabric example mod...${NC}"
  git clone "$FABRIC_REPO" "$PROJECT_DIR" || return
  cd "$PROJECT_DIR" || return

  mkdir -p run/mods
  mkdir -p run/config

  echo -e "${GREEN}[2/6] Add mods + config now? (y/N)${NC}"
  read -r SELECT_MODS || true

  if [[ "$SELECT_MODS" =~ ^[Yy]$ ]]; then
    mkdir -p "$PROJECT_DIR/mods"
    open "$PROJECT_DIR/mods"

    echo
    echo "Place:"
    echo "  - .jar files"
    echo "  - optional config folder"
    echo "Into:"
    echo "  $PROJECT_DIR/mods"
    echo

    read -r -p "Press ENTER when done..." _

    close_finder_window "$PROJECT_DIR/mods"
    move_mods_and_config "$PROJECT_DIR"
  fi

  echo -e "${GREEN}[3/6] Updating Minecraft version...${NC}"

  # Update gradle.properties safely
  if [ -f gradle.properties ]; then
    sed -i '' "s/^minecraft_version=.*/minecraft_version=$MC_VERSION/" gradle.properties 2>/dev/null || true
  fi

  echo -e "${GREEN}[4/6] Creating launcher...${NC}"

  cat > start-fabric.command <<EOF
#!/usr/bin/env bash
set -uo pipefail

PROJECT_DIR="$PROJECT_DIR"

move_mods_and_config() {
  SOURCE="\$PROJECT_DIR/mods"
  TARGET_MODS="\$PROJECT_DIR/run/mods"
  TARGET_CONFIG="\$PROJECT_DIR/run/config"

  mkdir -p "\$TARGET_MODS"
  mkdir -p "\$TARGET_CONFIG"

  if [ -d "\$SOURCE" ]; then
    find "\$SOURCE" -maxdepth 1 -type f -name '*.jar' -exec mv {} "\$TARGET_MODS"/ \;
  fi

  if [ -d "\$SOURCE/config" ]; then
    echo "Importing config folder..."
    rm -rf "\$TARGET_CONFIG"
    mv "\$SOURCE/config" "\$TARGET_CONFIG"
  fi
}

cd "\$PROJECT_DIR"

echo "Clean mods folder before moving? (y/N)"
read -r CLEAN

if [[ "\$CLEAN" =~ ^[Yy]$ ]]; then
  rm -f "\$PROJECT_DIR/run/mods"/*.jar 2>/dev/null || true
fi

move_mods_and_config

./gradlew runClient
EOF

  chmod +x start-fabric.command

  echo -e "${GREEN}[5/6] Creating uninstall...${NC}"

  cat > uninstall-fabric.command <<EOF
#!/usr/bin/env bash
echo "Delete $PROJECT_DIR ?"
read -r -p "Type DELETE to confirm: " ans
if [ "\$ans" = "DELETE" ]; then
  rm -rf "$PROJECT_DIR"
  echo "Deleted."
else
  echo "Cancelled."
fi
EOF

  chmod +x uninstall-fabric.command

  echo -e "${GREEN}[6/6] Run client now? (y/N)${NC}"
  read -r RUN_NOW || true

  if [[ "$RUN_NOW" =~ ^[Yy]$ ]]; then
    move_mods_and_config "$PROJECT_DIR"
    ./gradlew runClient
  fi

  echo
  echo -e "${GREEN}=== Fabric Setup Complete ===${NC}"
  echo "Project: $PROJECT_DIR"
  echo "Mods:    $PROJECT_DIR/run/mods"
  echo "Config:  $PROJECT_DIR/run/config"
  echo "Launcher: start-fabric.command"
}

run_fabric_setup
